# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# The SMTP server your email is hosted on
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false

# The account used to authenticate with the SMTP server
EMAIL_USER=your-smtp-user@yourdomain.com

# Gmail App Password (or SMTP password). Generate at: https://myaccount.google.com/apppasswords
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# IMPORTANT: EMAIL_FROM must match EMAIL_USER (or be a verified alias on the same SMTP server).
# Setting it to a different domain causes SPF/DKIM failures and spam rejection.
EMAIL_FROM=your-smtp-user@yourdomain.com

# Display name shown in the "From:" field of all emails
EMAIL_FROM_NAME=Jessica Eyebrow Threading

# Optional: replies from customers/merchant will go here (can be a different address)
EMAIL_REPLY_TO=yourpersonalemail@gmail.com

# The email address that receives new booking alerts
MERCHANT_EMAIL=yourpersonalemail@gmail.com

# ─── Security ─────────────────────────────────────────────────────────────────
# Allowed origin for CORS. Set this to your production domain.
# For local dev, you can set it to http://localhost:5173
ALLOWED_ORIGIN=https://jessicaeyebrowthreading.com

# Secret token to protect the /api/health endpoint
# Access via: /api/health?secret=YOUR_SECRET_HERE
HEALTH_CHECK_SECRET=replace-with-a-long-random-string

# ─── Server (local dev only) ───────────────────────────────────────────────────
PORT=5000

# ─── Vercel KV (production only) ──────────────────────────────────────────────
# These are set automatically when you link a Vercel KV store in the dashboard.
# Do NOT set these manually — copy them from your Vercel project's KV settings.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
