<!-- BottomNavBar (Mobile) -->
<nav class="md:hidden fixed bottom-0 left-0 w-full flex justify-around items-center pt-2 pb-safe px-4 bg-warm-white shadow-[0_-4px_20px_rgba(120,87,70,0.08)] z-50">
<a class="flex flex-col items-center justify-center text-on-surface-variant hover:text-primary transition-all duration-300 w-16 h-14" href="#">
<span class="material-symbols-outlined text-2xl mb-1" data-icon="home">home</span>
